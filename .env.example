# LLM Provider Configuration
LLM_BASE_URL=https://kiro.aidong-ai.com/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL=qwen2.5-coder-7b

# Embedding Model
EMBEDDING_MODEL=text-embedding-3-small

# Qdrant Vector Database
QDRANT_URL=http://localhost:6333

# 2D Asset Pipeline (ComfyUI sidecar)
ASSET_2D_URL=http://127.0.0.1:8100
COMFYUI_URL=http://127.0.0.1:8188
OUTPUT_DIR=/tmp/omni-assets

# Server Configuration
API_PORT=8080
RUST_LOG=info

# 3D Pipeline Configuration
PIPELINE3D_TRIPOSR_DEVICE=cuda
PIPELINE3D_SDXL_API_URL=
PIPELINE3D_SDXL_API_KEY=
PIPELINE3D_HUNYUAN3D_API_URL=
PIPELINE3D_HUNYUAN3D_API_KEY=
PIPELINE3D_DEFAULT_BACKEND=triposr
PIPELINE3D_OUTPUT_DIR=./output
PIPELINE3D_TEMP_DIR=./tmp
PIPELINE3D_BLENDER_PATH=blender
PIPELINE3D_USE_BLENDER_POSTPROCESS=false

# Pipeline 3D service URL (for API gateway proxy)
PIPELINE_3D_URL=http://localhost:8090

# Audio Pipeline
AUDIO_PIPELINE_URL=http://localhost:8090
AUDIO_DEVICE=cuda
AUDIO_DTYPE=float16

# Asset Director
ASSET_DIRECTOR_URL=http://localhost:8092
IMAGE_PIPELINE_URL=http://localhost:8091

# Auth — JWT signing secret (override in any non-dev environment)
AUTH_JWT_SECRET=omniagp-dev-secret-change-me

# GitHub OAuth (optional). Leave both blank to disable GitHub login;
# /api/v1/auth/github will then return 503 and the providers endpoint will
# advertise github=false so the UI hides the button.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Local user store (SQLite). Default uses the api_gateway_data docker volume.
USERS_DB_PATH=/data/users.db
